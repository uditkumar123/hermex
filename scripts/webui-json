#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
env_file="${HERMES_WEBUI_ENV_FILE:-"$repo_root/.env.local"}"

if [[ -f "$env_file" ]]; then
  set -a
  # shellcheck disable=SC1090
  source "$env_file"
  set +a
fi

: "${HERMES_WEBUI_BASE_URL:?Set HERMES_WEBUI_BASE_URL (e.g. https://your-server.example) in .env.local or the environment.}"
base_url="$HERMES_WEBUI_BASE_URL"
: "${HERMES_WEBUI_PASSWORD:?Set HERMES_WEBUI_PASSWORD in .env.local or the environment.}"

usage() {
  cat >&2 <<'USAGE'
Usage:
  scripts/webui-json sessions
  scripts/webui-json session <session_id> [msg_limit]
  scripts/webui-json path </api/path?query=...>
USAGE
}

urlencode() {
  python3 -c 'import sys, urllib.parse; print(urllib.parse.quote(sys.argv[1], safe=""))' "$1"
}

login_body() {
  python3 - <<'PY'
import json
import os
print(json.dumps({"password": os.environ["HERMES_WEBUI_PASSWORD"]}))
PY
}

if [[ $# -lt 1 ]]; then
  usage
  exit 2
fi

case "$1" in
  sessions)
    endpoint="/api/sessions"
    ;;
  session)
    if [[ $# -lt 2 ]]; then
      usage
      exit 2
    fi
    sid="$(urlencode "$2")"
    limit="${3:-50}"
    endpoint="/api/session?session_id=$sid&messages=1&msg_limit=$limit"
    ;;
  path)
    if [[ $# -lt 2 || "$2" != /api/* ]]; then
      usage
      exit 2
    fi
    endpoint="$2"
    ;;
  *)
    usage
    exit 2
    ;;
esac

cookie_jar="$(mktemp "${TMPDIR:-/tmp}/hermes-webui-cookie.XXXXXX")"
login_response="$(mktemp "${TMPDIR:-/tmp}/hermes-webui-login.XXXXXX")"
trap 'rm -f "$cookie_jar" "$login_response"' EXIT

login_status="$(
  login_body | curl -sS -o "$login_response" -w '%{http_code}' \
    -c "$cookie_jar" \
    -H 'Content-Type: application/json' \
    -X POST "$base_url/api/auth/login" \
    --data-binary @-
)"

if [[ "$login_status" != 2* ]]; then
  echo "WebUI login failed with HTTP $login_status" >&2
  cat "$login_response" >&2
  echo >&2
  exit 1
fi

curl -sS -b "$cookie_jar" "$base_url$endpoint"
