    "api/updates.py",
    "api/session_recovery.py",
    "docs/CONTRACTS.md",
    "docs/rfcs/",
    "CHANGELOG.md",
)

RISK_SUBJECT_KEYWORDS = (
    "api",
    "auth",
    "csrf",
    "session",
    "stream",
    "replay",
    "sse",
    "approval",
    "clarify",
    "goal",
    "model",
    "provider",
    "cron",
    "upload",
    "media",
    "workspace",
    "security",
    "compression",
    "lineage",
    "reasoning",
