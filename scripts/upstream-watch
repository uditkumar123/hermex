#!/usr/bin/env python3
"""Report upstream Hermes-WebUI changes that may affect Hermex."""

from __future__ import annotations

import argparse
import ast
import io
import re
import subprocess
import sys
import tokenize
from pathlib import Path


DEFAULT_UPSTREAM_DIR = ".codex-tmp/hermes-webui"
DEFAULT_BASE_SHA_FILE = "UPSTREAM_TESTED_SHA"
DEFAULT_TRIAGED_SHA_FILE = "UPSTREAM_TRIAGED_SHA"
DEFAULT_TARGET_REF = "origin/master"
# Past this many release tags behind the tested pin, the digest flags loudly so
# the validation debt cannot grow silently. See the advance policy in
# CONTRACT_TESTS.md.
DEFAULT_RELEASES_LOUD_THRESHOLD = 20

RISK_FILE_PATTERNS = (
    "api/routes.py",
    "api/streaming.py",
    "api/agent_sessions.py",
    "api/session_events.py",
    "api/route_approvals.py",
    "api/clarify.py",
    "api/goals.py",
    "api/models.py",
    "api/providers.py",
    "api/config.py",
    "api/profiles.py",
