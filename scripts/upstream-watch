    "ios",
)

# Canonical ordering for the upstream CHANGELOG's `### <Category>` sections.
# Categories found in the CHANGELOG that are not listed here are rendered after
# these, alphabetically, so an upstream-added category is never silently dropped.
CHANGELOG_CATEGORY_ORDER = ("Added", "Changed", "Fixed", "Security", "Removed")

# Route classification is read from the machine-readable table in the feature-gap
# index (issue #173). Buckets:
#   "roadmap" — a known upstream feature tracked as a future/deferred mobile slice.
#   "n-a"     — web/desktop/server-internal; no mobile implementation expected.
# "implemented" is deliberately NOT in the index — it is derived live from
# `Endpoints.swift` (see classify_route) so it can never drift from what the app
# actually ships. A route matching neither is "new" — the uncatalogued surface
# this digest exists to surface.
FEATURE_GAP_INDEX_REL_PATH = "docs/agents/feature-gap-index.md"
CLASSIFICATION_BUCKETS = frozenset({"roadmap", "n-a"})
# A classification row: `| `<prefix>` | <status> | <priority> | <safety> | <note> |`.
# The prefix cell is a backtick-wrapped path; the priority cell, when meaningful,
# is appended to the note to form the digest label.
CLASSIFICATION_PREFIX_RE = re.compile(r"`(/[^`]+)`")
CLASSIFICATION_EMPTY_PRIORITIES = frozenset({"—", "-", "n/a", ""})


def load_route_classification(repo_root: Path) -> tuple[tuple[str, str, str], ...]:
    """Parse `(prefix, bucket, label)` rows from the feature-gap index table.

    Rows are returned in file order so matching is first-match-wins; the index
    lists specific prefixes before general ones (e.g. `/api/file/reveal` before
    `/api/file/`). Only `roadmap`/`n-a` rows are read — `implemented` is derived
    live from `Endpoints.swift` and `new` is the fallthrough, so neither is
    encoded here.

    Degrades to an empty tuple (every route then classifies as implemented-or-new)
    when the index is missing or has no parseable rows, so a moved/renamed index
    never crashes the digest. Mirrors the other extractors' tolerant degrade.
    """
    index_file = repo_root / FEATURE_GAP_INDEX_REL_PATH
    if not index_file.exists():
        print(f"warning: feature-gap index not found: {index_file}", file=sys.stderr)
        return ()
    rows: list[tuple[str, str, str]] = []
    for line in index_file.read_text(encoding="utf-8").splitlines():
        stripped = line.strip()
        if not stripped.startswith("|"):
            continue
        # Cap the split at 4 so the trailing note column (cells[4]) absorbs any
        # literal `|` a future note might contain, instead of truncating it.
        cells = [cell.strip() for cell in stripped.strip("|").split("|", 4)]
        if len(cells) < 5:
            continue
        prefix_match = CLASSIFICATION_PREFIX_RE.fullmatch(cells[0])
        if prefix_match is None:
            continue
        bucket = cells[1].lower()
        if bucket not in CLASSIFICATION_BUCKETS:
            continue
        prefix, priority, note = prefix_match.group(1), cells[2], cells[4]
        label = f"{note} ({priority})" if priority not in CLASSIFICATION_EMPTY_PRIORITIES else note
        rows.append((prefix, bucket, label))
    if not rows:
        print(f"warning: no classification rows parsed from {index_file}", file=sys.stderr)
    return tuple(rows)


def run_git(repo: Path, args: list[str], *, check: bool = True) -> str:
    result = subprocess.run(
        ["git", "-C", str(repo), *args],
        check=False,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
    )
    if check and result.returncode != 0:
        raise SystemExit(
            f"git {' '.join(args)} failed in {repo}\n{result.stderr.strip()}"
        )
    return result.stdout


def git_show(repo: Path, ref: str, file_path: str) -> str:
    result = subprocess.run(
        ["git", "-C", str(repo), "show", f"{ref}:{file_path}"],
        check=False,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.DEVNULL,
    )
    return result.stdout if result.returncode == 0 else ""


def normalize_route_path(value: str) -> str | None:
    if any(character.isspace() for character in value):
        return None
    value = value.split("?", 1)[0].rstrip("/")
    value = value.rstrip(".,;:)]")
    value = re.sub(r"\{[^}]+\}", "{param}", value)
    if value.startswith("/api") or value == "/health":
        return value
    return None


def extract_route_paths(text: str) -> set[str]:
    paths = set()
    try:
        tokens = tokenize.generate_tokens(io.StringIO(text).readline)
        for token in tokens:
            if token.type != tokenize.STRING:
                continue
            try:
                value = ast.literal_eval(token.string)
            except (SyntaxError, ValueError):
                continue
            if not isinstance(value, str):
                continue
            route_path = normalize_route_path(value)
            if route_path:
                paths.add(route_path)
    except tokenize.TokenError:
        return paths
    return paths


# A request key is a snake_case identifier: a lowercase first char followed by
# lowercase letters, digits, or underscores. This is the noise heuristic — it
# drops header names (`Content-Type`), env vars (`HOME`), and other uppercase or
# hyphenated `.get(...)` arguments that are not request params/fields.
REQUEST_KEY_RE = re.compile(r"[a-z][a-z0-9_]*")


def extract_request_keys(text: str) -> set[str]:
    """Return request-key string literals read via `.get("<key>")` in `routes.py`.

    Upstream reads request params/fields through `.get(...)` on `request.args`,
    `request.json`, `request.form`, or a decoded `data` dict, plus bare
    `.get(...)` chains. We treat *any* `.get("<literal>")` whose first positional
    argument is a snake_case string literal as a request key — the receiver is
    intentionally not constrained, since upstream accesses keys through several
    aliases; `REQUEST_KEY_RE` is what keeps the result low-noise. Both quote
    styles are handled for free because `ast` evaluates the literal.

    Degrades to an empty set on a parse error so a malformed/renamed routes.py
    never fails the whole digest (mirrors `extract_route_paths`).
    """
    keys: set[str] = set()
    try:
        tree = ast.parse(text)
    except (SyntaxError, ValueError):
        return keys
    for node in ast.walk(tree):
        if not isinstance(node, ast.Call):
            continue
        func = node.func
        if not isinstance(func, ast.Attribute) or func.attr != "get" or not node.args:
            continue
        first = node.args[0]
        if not isinstance(first, ast.Constant) or not isinstance(first.value, str):
            continue
        if REQUEST_KEY_RE.fullmatch(first.value):
            keys.add(first.value)
    return keys


# Upstream streams a few wire events through callback dispatch (the agent run /
# streaming callbacks) rather than a literal `_sse(handler, "<name>", ...)` call,
# so the AST scan below cannot see them. They are still part of the wire contract
# the app must handle, so we union them in explicitly. See issue #186.
CALLBACK_SSE_EVENT_NAMES = frozenset(
    {"token", "reasoning", "tool", "tool_complete", "title", "done", "interim_assistant"}
)


def extract_sse_event_names(text: str) -> set[str]:
    """Return SSE wire event names emitted via `_sse(handler, "<name>", ...)`.

    Upstream streams every wire event through `_sse(handler, "<event>", data)`;
    the event name is the *second* positional argument, or an `event=` keyword if
    upstream ever switches to keyword calls. We collect only string literals there
    — call sites that pass a variable or a dynamic name like
    `event_data.get("type", ...)` are skipped, since the name is not statically
    knowable. Both quote styles work because `ast` evaluates the literal. Matches
    the `_sse` callee whether it is a bare name or an attribute (e.g. `self._sse`).

    Degrades to an empty set on a parse error so a malformed/renamed source file
    never fails the whole digest (mirrors `extract_route_paths`).
    """
    names: set[str] = set()
    try:
        tree = ast.parse(text)
    except (SyntaxError, ValueError):
        return names
    for node in ast.walk(tree):
        if not isinstance(node, ast.Call):
            continue
        func = node.func
        callee = (
            func.id if isinstance(func, ast.Name)
            else func.attr if isinstance(func, ast.Attribute)
            else None
        )
        if callee != "_sse":
            continue
        # Prefer the 2nd positional arg; fall back to an `event=` keyword so a
        # future switch to keyword calls does not silently drop the event name.
        event = node.args[1] if len(node.args) >= 2 else next(
            (kw.value for kw in node.keywords if kw.arg == "event"), None
        )
        if isinstance(event, ast.Constant) and isinstance(event.value, str):
            names.add(event.value)
    return names


# A case label made entirely of comma-separated string literals followed by `:`.
# Anchoring on quoted literals avoids matching enum `case token(...)` declarations
# (which carry no string) and keeps the match on a single label, never spanning.
SSE_CASE_RE = re.compile(r'\bcase\s+("[^"]*"(?:\s*,\s*"[^"]*")*)\s*:')
SSE_STRING_RE = re.compile(r'"([^"]*)"')


def extract_app_sse_cases(repo_root: Path) -> set[str]:
    """Return the SSE wire names the app handles, from `SSEClient.swift` `case`s.

    Degrades to an empty set when the file is absent so a moved/renamed client
    never fails the digest (mirrors the other Swift-side extractors).
    """
    sse_file = repo_root / "HermesMobile/Networking/SSEClient.swift"
    if not sse_file.exists():
        return set()
    text = sse_file.read_text(encoding="utf-8")
    names: set[str] = set()
    for label in SSE_CASE_RE.findall(text):
        names.update(SSE_STRING_RE.findall(label))
    return names


def extract_mobile_paths(repo_root: Path) -> set[str]:
    endpoints_file = repo_root / "HermesMobile/Networking/Endpoints.swift"
    if not endpoints_file.exists():
        return set()
    text = endpoints_file.read_text(encoding="utf-8")
    paths = set()
    for match in re.finditer(r'return "([^"]+)"', text):
        value = match.group(1).rstrip("/")
        if value.startswith("/api") or value == "/health":
            paths.add(value)
    return paths


def extract_contract_test_paths(repo_root: Path) -> set[str]:
    test_file = repo_root / "HermesMobileTests/APIEndpointContractTests.swift"
    if not test_file.exists():
        return set()
    text = test_file.read_text(encoding="utf-8")
    paths = set()
    for match in re.finditer(r'path: "((?:/api|/health)[^"]*)"', text):
        paths.add(match.group(1).rstrip("/"))
    return paths


def changed_files(repo: Path, base_ref: str, target_ref: str) -> list[str]:
    output = run_git(repo, ["diff", "--name-only", f"{base_ref}..{target_ref}"])
    return [line.strip() for line in output.splitlines() if line.strip()]


def risk_files(files: list[str]) -> list[str]:
    return [
        file_path
        for file_path in files
        if any(file_path == pattern or file_path.startswith(pattern) for pattern in RISK_FILE_PATTERNS)
    ]


def commit_subjects(repo: Path, base_ref: str, target_ref: str, limit: int) -> list[str]:
    output = run_git(
        repo,
        [
            "log",
            "--date=short",
            "--pretty=format:%h %ad %s",
            f"{base_ref}..{target_ref}",
            f"-n{limit}",
        ],
    )
    return [line for line in output.splitlines() if line.strip()]


def risk_subjects(subjects: list[str]) -> list[str]:
    risky = []
    for subject in subjects:
        lowered = subject.lower()
        if any(keyword in lowered for keyword in RISK_SUBJECT_KEYWORDS):
            risky.append(subject)
    return risky


def parse_changelog_bullets(text: str) -> list[tuple[str, str]]:
    """Return `(category, bullet)` pairs in document order.

    Each bullet is attributed to its nearest preceding `### <Category>` heading.
    A `## ` release heading resets the category to None so a stray bullet is
    never attributed across release blocks. Sub-bullets (indented `- `) are
    captured too, keyed to the same category. The bullet text retains its
    leading `- ` so it can be rendered verbatim.

    Known limitation: only the first physical line of a bullet is captured.
    Upstream CHANGELOG.md writes each bullet on a single line (each ending in a
    `(#PR, @author)` suffix), so this does not truncate today; revisit only if
    upstream starts wrapping bullets across lines.
    """
    pairs: list[tuple[str, str]] = []
    category: str | None = None
    for raw in text.splitlines():
        line = raw.rstrip()
        if line.startswith("### "):
            category = line[4:].strip()
            continue
        if line.startswith("## "):
            category = None
            continue
        stripped = line.lstrip()
        if stripped.startswith("- "):
            pairs.append((category or "Uncategorized", stripped))
    return pairs


def changelog_added_bullets(
    repo: Path, triaged_ref: str, target_ref: str
) -> tuple[dict[str, list[str]], bool, bool]:
    """Compute CHANGELOG bullets present at `target_ref` but absent at `triaged_ref`.

    Returns (grouped, triaged_present, target_present) where `grouped` maps a
    `### <Category>` name to its added bullets in document order. Membership is
    compared by exact bullet text across all categories, so a bullet that merely
    moved between categories is not reported as new. Missing CHANGELOG.md at
    either ref degrades to an empty delta via `git_show`'s empty-string return.
    """
    triaged_text = git_show(repo, triaged_ref, "CHANGELOG.md")
    target_text = git_show(repo, target_ref, "CHANGELOG.md")
    triaged_present = bool(triaged_text.strip())
    target_present = bool(target_text.strip())

    triaged_bullets = {bullet for _, bullet in parse_changelog_bullets(triaged_text)}
    grouped: dict[str, list[str]] = {}
    seen: set[str] = set()
    for category, bullet in parse_changelog_bullets(target_text):
        if bullet in triaged_bullets or bullet in seen:
            continue
        seen.add(bullet)
        grouped.setdefault(category, []).append(bullet)
    return grouped, triaged_present, target_present


def describe(repo: Path, ref: str) -> str:
    value = run_git(repo, ["describe", "--tags", "--always", ref]).strip()
    sha = run_git(repo, ["rev-parse", ref]).strip()
    return f"{value} ({sha})"


def read_ref_file(path: Path, label: str) -> str:
    value = path.read_text(encoding="utf-8").strip()
    if not value:
        raise SystemExit(f"{label} ref is empty: {path}")
    return value


def count_releases_behind(repo: Path, base_ref: str, target_ref: str) -> int | None:
    """Count release tags reachable from target but not from the tested base.

    This is the honest "releases behind" metric: it counts release tags
    (`v[0-9]*`, e.g. `v0.51.325`) the target is ahead of the pinned tested SHA.
    Restricting to the version-tag pattern keeps temporary or experimental
    upstream tags from skewing the count. Returns None when tag data is
    unavailable (e.g. tags were not fetched into the upstream clone) so the
    report degrades to "unknown" instead of failing the whole digest.
    """
    target_out = run_git(repo, ["tag", "--merged", target_ref, "--list", "v[0-9]*"], check=False)
    if not target_out.strip():
        return None
    base_out = run_git(repo, ["tag", "--merged", base_ref, "--list", "v[0-9]*"], check=False)
    base_tags = {line.strip() for line in base_out.splitlines() if line.strip()}
    target_tags = {line.strip() for line in target_out.splitlines() if line.strip()}
    return len(target_tags - base_tags)


def bullet_list(values: list[str], *, empty: str, limit: int | None = None) -> list[str]:
    selected = values if limit is None else values[:limit]
    if not selected:
        return [f"- {empty}"]
    lines = [f"- `{value}`" for value in selected]
    if limit is not None and len(values) > limit:
        lines.append(f"- ... {len(values) - limit} more")
    return lines


def classify_route(
    path: str,
    mobile_paths: set[str],
    classification: tuple[tuple[str, str, str], ...],
) -> tuple[str, str | None]:
    """Bucket one upstream route path.

    Returns (bucket, label). "implemented" is decided live against the app's own
    `Endpoints.swift` paths; "roadmap"/"n-a" come from the feature-gap index
    classification; a route matching nothing is "new" — the uncatalogued surface
    to triage.
    """
    if path in mobile_paths:
        return "implemented", None
    for prefix, bucket, label in classification:
        # Upstream paths are normalized without a trailing slash, so match the
        # bare group path as well as any sub-path regardless of whether the
        # index entry was written with a trailing slash.
        base = prefix.rstrip("/")
        if path == base or path.startswith(base + "/"):
            return bucket, label
    return "new", None


def classify_routes(
    paths: list[str],
    mobile_paths: set[str],
    classification: tuple[tuple[str, str, str], ...],
) -> tuple[dict[str, list[str]], dict[str, str]]:
    buckets: dict[str, list[str]] = {"new": [], "roadmap": [], "implemented": [], "n-a": []}
    labels: dict[str, str] = {}
    for path in paths:
        bucket, label = classify_route(path, mobile_paths, classification)
        buckets[bucket].append(path)
        if label:
            labels[path] = label
    return buckets, labels


def route_group(path: str) -> str:
    """Coarse feature group for a route, used to cluster the new/unclassified
    bucket so related routes (passkeys, git, notes, ...) read as one line
    instead of scrolling past individually."""
    if "passkey" in path:
        return "passkeys"
    parts = [segment for segment in path.split("/") if segment]
    if len(parts) >= 2:
        group = parts[1]
        return "session" if group == "sessions" else group
    return parts[-1] if parts else path


def render_classified_routes(
    buckets: dict[str, list[str]], labels: dict[str, str], route_limit: int
) -> list[str]:
    new = sorted(buckets["new"])
    roadmap = sorted(buckets["roadmap"])
    implemented = sorted(buckets["implemented"])
    not_applicable = sorted(buckets["n-a"])
    total = len(new) + len(roadmap) + len(implemented) + len(not_applicable)

    lines = [
        f"Bucketed `{total}` unvalidated route literals so the genuinely new "
        "surface leads. `implemented` is derived from `Endpoints.swift`; "
        "`roadmap`/`n-a` come from the `docs/agents/feature-gap-index.md` "
        "classification table.",
        "",
    ]

    # Lead with new / unclassified, grouped by feature so passkeys/git/notes/...
    # stand out instead of being buried in a flat wall.
    new_groups: dict[str, list[str]] = {}
    for path in new:
        new_groups.setdefault(route_group(path), []).append(path)
    lines.append(f"### New / unclassified ({len(new)} routes, {len(new_groups)} groups)")
    lines.append("")
    if new:
        lines.append(
            "Not in `Endpoints.swift` and not in the feature-gap index — these need a triage decision."
        )
        # Biggest groups first, then alphabetical, so the heaviest new surfaces lead.
        for group in sorted(new_groups, key=lambda name: (-len(new_groups[name]), name)):
            members = new_groups[group]
            shown = members[:route_limit]
            joined = ", ".join(f"`{member}`" for member in shown)
            if len(members) > route_limit:
                joined += f", ... {len(members) - route_limit} more"
            lines.append(f"- **{group}** ({len(members)}): {joined}")
    else:
        lines.append("- None")

    # Already-classified buckets: counts up front, full lists collapsed so they
    # never drown out the new surface.
    lines.extend(["", "### Already classified (counts; lists collapsed)", ""])
    lines.append(f"- **Implemented** (`{len(implemented)}`) — present in `Endpoints.swift`")
    lines.append(f"- **Roadmap** (`{len(roadmap)}`) — tracked in the feature-gap index")
    lines.append(f"- **n-a** (`{len(not_applicable)}`) — web/desktop/server-internal, no mobile fit")

    if implemented:
        lines.extend(["", "<details>", f"<summary>Implemented ({len(implemented)})</summary>", ""])
        lines.extend(f"- `{path}`" for path in implemented)
        lines.append("</details>")
    if roadmap:
        lines.extend(["", "<details>", f"<summary>Roadmap ({len(roadmap)})</summary>", ""])
        lines.extend(f"- `{path}` — {labels.get(path, '')}" for path in roadmap)
        lines.append("</details>")
    if not_applicable:
        lines.extend(["", "<details>", f"<summary>n-a ({len(not_applicable)})</summary>", ""])
        lines.extend(f"- `{path}` — {labels.get(path, '')}" for path in not_applicable)
        lines.append("</details>")

    return lines


def render_changelog_section(
    grouped: dict[str, list[str]],
    *,
    triaged_present: bool,
    target_present: bool,
    limit: int,
) -> list[str]:
    """Render the added CHANGELOG bullets grouped by category.

    Categories follow CHANGELOG_CATEGORY_ORDER, then any extras alphabetically.
    Per-category bullet lists are capped at `limit`; truncation appends an
    `- ... N more` marker (and a stderr notice) so nothing is silently dropped.
    """
    # Degrade up front when CHANGELOG.md is absent at either ref. A missing
    # triaged file means there is no baseline to diff against, so every target
    # bullet would otherwise be reported as "new" (the whole file's history) —
    # that is not a delta, so we say so instead of dumping it.
    if not target_present:
        return ["- None (CHANGELOG.md not present at target ref)."]
    if not triaged_present:
        return ["- None (CHANGELOG.md not present at triaged ref — no delta computable)."]

    ordered = [name for name in CHANGELOG_CATEGORY_ORDER if name in grouped]
    extras = sorted(name for name in grouped if name not in CHANGELOG_CATEGORY_ORDER)
    categories = ordered + extras

    if not categories:
        return ["- None (no new bullets since last triage)."]

    lines: list[str] = []
    for category in categories:
        bullets = grouped[category]
        shown = bullets[:limit]
        lines.extend([f"### {category}", ""])
        lines.extend(shown)
        if len(bullets) > limit:
            dropped = len(bullets) - limit
            lines.append(f"- ... {dropped} more")
            print(
                f"upstream-watch: CHANGELOG section '{category}' truncated "
                f"{dropped} of {len(bullets)} bullets (raise --changelog-limit "
                "to show all).",
                file=sys.stderr,
            )
        lines.append("")
    # Drop the trailing blank so the caller controls section spacing.
    if lines and lines[-1] == "":
        lines.pop()
    return lines


def render_request_keys(keys: list[str], limit: int) -> list[str]:
    """Render added request-key literals, capped at `limit`.

    `bullet_list` already appends the `- ... N more` marker on truncation; we add
    a stderr notice so the cap is never silent (mirrors the CHANGELOG section).
    """
    if len(keys) > limit:
        dropped = len(keys) - limit
        print(
            f"upstream-watch: request-keys section truncated {dropped} of "
            f"{len(keys)} keys (raise --request-key-limit to show all).",
            file=sys.stderr,
        )
    return bullet_list(keys, empty="None", limit=limit)


def render_sse_unhandled(events: list[str], limit: int) -> list[str]:
    """Render upstream SSE wire events the app's SSEClient doesn't handle.

    Mirrors `render_request_keys`: `bullet_list` adds the `- ... N more` marker on
    truncation and we emit a stderr notice so the cap is never silent.
    """
    if len(events) > limit:
        dropped = len(events) - limit
        print(
            f"upstream-watch: SSE-events section truncated {dropped} of "
            f"{len(events)} events (raise --sse-event-limit to show all).",
            file=sys.stderr,
        )
    return bullet_list(events, empty="None", limit=limit)


def build_report(args: argparse.Namespace) -> str:
    repo_root = Path(args.repo_root).resolve()
    upstream_dir = (repo_root / args.upstream_dir).resolve()
    base_sha_file = repo_root / args.base_sha_file
    triaged_sha_file = repo_root / args.triaged_sha_file

    if not upstream_dir.exists():
        raise SystemExit(f"Upstream repo not found: {upstream_dir}")
    if not base_sha_file.exists():
        raise SystemExit(f"Base SHA file not found: {base_sha_file}")

    if args.fetch:
        run_git(upstream_dir, ["fetch", "--tags", "origin", "master"])

    base_ref = read_ref_file(base_sha_file, "Base SHA")
    triaged_ref = read_ref_file(triaged_sha_file, "Triaged SHA") if triaged_sha_file.exists() else base_ref
    target_ref = args.target_ref.strip() if args.target_ref else DEFAULT_TARGET_REF
    base_routes = git_show(upstream_dir, base_ref, "api/routes.py")
    triaged_routes = git_show(upstream_dir, triaged_ref, "api/routes.py")
    target_routes = git_show(upstream_dir, target_ref, "api/routes.py")

    base_paths = extract_route_paths(base_routes)
    triaged_paths = extract_route_paths(triaged_routes)
    target_paths = extract_route_paths(target_routes)
    triaged_request_keys = extract_request_keys(triaged_routes)
    target_request_keys = extract_request_keys(target_routes)
    added_request_keys = sorted(target_request_keys - triaged_request_keys)
    target_streaming = git_show(upstream_dir, target_ref, "api/streaming.py")
    upstream_sse_events = (
        extract_sse_event_names(target_routes)
        | extract_sse_event_names(target_streaming)
        | set(CALLBACK_SSE_EVENT_NAMES)
    )
    app_sse_cases = extract_app_sse_cases(repo_root)
    unhandled_sse_events = sorted(upstream_sse_events - app_sse_cases)
    mobile_paths = extract_mobile_paths(repo_root)
    contract_paths = extract_contract_test_paths(repo_root)
    route_classification = load_route_classification(repo_root)

    added_paths_since_tested = sorted(target_paths - base_paths)
    removed_paths_since_tested = sorted(base_paths - target_paths)
    added_paths_since_triage = sorted(target_paths - triaged_paths)
    removed_paths_since_triage = sorted(triaged_paths - target_paths)
    missing_mobile_paths = sorted(mobile_paths - target_paths)
    untested_mobile_paths = sorted(mobile_paths - contract_paths)

    files_since_tested = changed_files(upstream_dir, base_ref, target_ref)
    files_since_triage = changed_files(upstream_dir, triaged_ref, target_ref)
    risky_files_since_tested = risk_files(files_since_tested)
    risky_files_since_triage = risk_files(files_since_triage)
    subjects = commit_subjects(upstream_dir, triaged_ref, target_ref, args.commit_limit)
    risky_subjects = risk_subjects(subjects)
    changelog_grouped, changelog_triaged_present, changelog_target_present = (
        changelog_added_bullets(upstream_dir, triaged_ref, target_ref)
    )

    releases_behind = count_releases_behind(upstream_dir, base_ref, target_ref)
    releases_behind_display = (
        str(releases_behind) if releases_behind is not None else "unknown (run with --fetch)"
    )
    loud_releases = (
        releases_behind is not None
        and releases_behind >= args.releases_loud_threshold
    )
    loud_bullet = None
    if loud_releases:
        loud_bullet = (
            f"- ⚠️ LOUD: tested pin is {releases_behind} releases behind target "
            f"(threshold {args.releases_loud_threshold}). Run a live-smoke of the read-only "
            "CONTRACT_TESTS.md groups + the disposable-session mutate, then advance "
            "`UPSTREAM_TESTED_SHA` to the validated release."
        )

    has_breakage_signal = bool(missing_mobile_paths or removed_paths_since_triage)
    has_coverage_signal = bool(untested_mobile_paths or unhandled_sse_events)
    has_new_triage_signal = bool(
        files_since_triage
        or added_paths_since_triage
        or removed_paths_since_triage
        or added_request_keys
    )
    if has_breakage_signal:
        verdict = "Review required: possible endpoint compatibility issue detected."
    elif has_coverage_signal:
        verdict = "Review recommended: local endpoint contract coverage gaps detected."
    elif has_new_triage_signal:
        verdict = "Review recommended: new upstream changes since the last triaged SHA."
    elif risky_files_since_tested:
        verdict = "No new triage delta; upstream remains ahead of the tested SHA."
    else:
        verdict = "No immediate upstream-watch action detected."

    lines = [
        "# Hermes-WebUI Upstream Watch",
        "",
        "## Triage Verdict",
        "",
        *([loud_bullet] if loud_bullet else []),
        f"- {verdict}",
        f"- Releases behind tested pin: `{releases_behind_display}`",
        f"- Mobile endpoint paths removed from target: `{len(missing_mobile_paths)}`",
        f"- Local contract-matrix gaps: `{len(untested_mobile_paths)}`",
        f"- New route literals since last triage: `{len(added_paths_since_triage)}`",
        f"- Removed route literals since last triage: `{len(removed_paths_since_triage)}`",
        f"- New request keys since last triage: `{len(added_request_keys)}`",
        f"- Upstream SSE events not handled by app: `{len(unhandled_sse_events)}`",
        f"- High-signal files changed since last triage: `{len(risky_files_since_triage)}`",
        "",
        "## Baselines",
        "",
        f"- Tested base: `{describe(upstream_dir, base_ref)}`",
        f"- Last triaged: `{describe(upstream_dir, triaged_ref)}`",
        f"- Target: `{describe(upstream_dir, target_ref)}`",
        f"- Releases behind tested pin: `{releases_behind_display}` "
        f"(loud threshold `{args.releases_loud_threshold}`)",
        f"- Changed files since tested base: `{len(files_since_tested)}`",
        f"- Changed files since last triage: `{len(files_since_triage)}`",
        f"- High-signal changed files since tested base: `{len(risky_files_since_tested)}`",
        "",
        "## Endpoint Compatibility",
        "",
    ]

    if missing_mobile_paths:
        lines.append("Mobile endpoint paths not found in target upstream:")
        lines.extend(bullet_list(missing_mobile_paths, empty="None"))
    else:
        lines.append("No mobile endpoint paths appear removed from target upstream.")

    lines.extend(["", "Mobile endpoint paths missing from the local contract matrix:"])
    lines.extend(bullet_list(untested_mobile_paths, empty="None"))

    lines.extend(["", "## New Route Literals Since Last Triage", ""])
    lines.extend(bullet_list(added_paths_since_triage, empty="None", limit=args.route_limit))

    lines.extend(["", "## Removed Route Literals Since Last Triage", ""])
    lines.extend(bullet_list(removed_paths_since_triage, empty="None", limit=args.route_limit))

    lines.extend(["", "## High-Signal Changed Files Since Last Triage", ""])
    lines.extend(bullet_list(risky_files_since_triage, empty="None", limit=args.file_limit))

    lines.extend(["", "## Risk-Keyword Commit Subjects Since Last Triage", ""])
    if risky_subjects:
        lines.extend(f"- {subject}" for subject in risky_subjects[: args.commit_limit])
    else:
        lines.append("- None in the inspected commit window.")

    lines.extend(["", "## Upstream CHANGELOG Since Last Triage", ""])
    lines.extend(
        render_changelog_section(
            changelog_grouped,
            triaged_present=changelog_triaged_present,
            target_present=changelog_target_present,
            limit=args.changelog_limit,
        )
    )

    lines.extend(["", "## New Request Keys Since Last Triage", ""])
    lines.extend(render_request_keys(added_request_keys, args.request_key_limit))

    lines.extend(["", "## SSE Event Types Not Handled By App", ""])
    lines.append(
        "_Wire `event:` names only; inner `event_type` fields (`tool.started`, etc.) "
        "are out of scope for this slice._"
    )
    lines.append("")
    lines.extend(render_sse_unhandled(unhandled_sse_events, args.sse_event_limit))

    lines.extend(["", "## Unvalidated Route Literals Since Tested Base", ""])
    classified_buckets, classification_labels = classify_routes(
        added_paths_since_tested, mobile_paths, route_classification
    )
    lines.extend(
        render_classified_routes(classified_buckets, classification_labels, args.route_limit)
    )

    lines.extend(["", "Removed route literals since tested base:"])
    lines.extend(bullet_list(removed_paths_since_tested, empty="None", limit=args.route_limit))

    lines.extend(
        [
            "",
            "## Recommended Triage",
            "",
            "- Create `needs-triage` issues for removed mobile paths, streaming/run-state changes, auth/CSRF changes, model/provider routing changes, session schema changes, and upload/media/workspace security changes.",
            "- Promote to `ready-for-agent` only after app impact and acceptance criteria are clear.",
            "- Advance `UPSTREAM_TESTED_SHA` per the advance policy in `CONTRACT_TESTS.md`: after a green live-smoke of the read-only groups + the disposable-session mutate, move the pin to the validated release.",
            "- Update `UPSTREAM_TRIAGED_SHA` after the digest is reviewed and any follow-up issues are created.",
        ]
    )

    return "\n".join(lines) + "\n"


def main() -> int:
    parser = argparse.ArgumentParser(
        description="Generate a markdown upstream-watch report for Hermes-WebUI changes."
    )
    parser.add_argument("--repo-root", default=".", help="Hermex repository root.")
    parser.add_argument("--upstream-dir", default=DEFAULT_UPSTREAM_DIR)
    parser.add_argument("--base-sha-file", default=DEFAULT_BASE_SHA_FILE)
    parser.add_argument("--triaged-sha-file", default=DEFAULT_TRIAGED_SHA_FILE)
    parser.add_argument("--target-ref", default=DEFAULT_TARGET_REF)
    parser.add_argument("--fetch", action="store_true", help="Fetch origin/master and tags first.")
    parser.add_argument(
        "--releases-loud-threshold",
        type=int,
        default=DEFAULT_RELEASES_LOUD_THRESHOLD,
        help="Loudly flag when the tested pin is at least this many release tags behind target.",
    )
    parser.add_argument("--route-limit", type=int, default=80)
    parser.add_argument("--file-limit", type=int, default=80)
    parser.add_argument("--commit-limit", type=int, default=60)
    parser.add_argument(
        "--changelog-limit",
        type=int,
        default=40,
        help="Max added CHANGELOG bullets to show per ### category before truncating.",
    )
    parser.add_argument(
        "--request-key-limit",
        type=int,
        default=80,
        help="Max added request-key literals to show before truncating.",
    )
    parser.add_argument(
        "--sse-event-limit",
        type=int,
        default=40,
        help="Max unhandled SSE wire event names to show before truncating.",
    )
    args = parser.parse_args()

    sys.stdout.write(build_report(args))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
