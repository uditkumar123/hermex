<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Hermex connects to user-specified self-hosted servers. HTTPS is recommended
         but cleartext HTTP is permitted for local-network and Tailscale (100.64.0.0/10)
         deployments where TLS is impractical.

         SECURITY: The app validates non-local HTTP connections at runtime and logs
         a warning. Users should prefer HTTPS via Cloudflare Tunnel, Tailscale Funnel,
         or a reverse proxy for any server reachable from the public internet.

         Production hardening backlog:
         - User-pinned certificate fingerprint (TrustKit / OkHttp CertificatePinner)
         - Per-server trust anchor configuration
         See: https://developer.android.com/privacy-and-security/security-config -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
