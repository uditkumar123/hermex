<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- All connections to user-specified self-hosted servers.
         HTTPS is recommended but not required — users on local networks
         or Tailscale may use HTTP. -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- NOTE: SSL certificate pinning is not yet implemented.
         The app connects to user-specified self-hosted servers whose certificates
         vary. Pin enforcement would break valid connections. Future hardening:
         - Allow users to pin their server's certificate fingerprint
         - Use TrustKit or OkHttp CertificatePinner for known servers
         See: https://developer.android.com/privacy-and-security/security-config#certificate-pinning -->
</network-security-config>
